pipeline {
    agent any
    environment {
        CI = 'true'
    }
    stages {
        stage('Install Dependencies') {
            steps {
                bat 'pip install -r requirements.txt'
            }
        }
        stage('API Tests') {
            steps {
                bat 'pytest tests/test_api/ -v'
            }
        }
        stage('UI Tests') {
            steps {
                bat 'pytest tests/test_ui/ -v'
            }
        }
        stage('Hybrid Tests') {
            steps {
                bat 'pytest tests/test_hybrid/ -v'
            }
        }
        stage('Full Report') {
            steps {
                bat 'pytest tests/ --html=reports/report.html --self-contained-html'
            }
        }
    }
        post {
        always {
            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'reports',
                reportFiles: 'report.html',
                reportName: 'Test Report'
            ])
        }
    }
}